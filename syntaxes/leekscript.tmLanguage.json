{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "LeekScript",
  "scopeName": "source.leek",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation",
          "begin": "//(/|!)",
          "end": "$",
          "patterns": [
            { "include": "#doxygen-tags" }
          ]
        },
        {
          "name": "comment.line",
          "match": "//.*$"
        },
        {
          "name": "comment.block.documentation",
          "begin": "/\\*\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#doxygen-tags" }
          ]
        },
        {
          "name": "comment.block.documentation",
          "begin": "/\\*!",
          "end": "\\*/",
          "patterns": [
            { "include": "#doxygen-tags" }
          ]
        },
        {
          "name": "comment.block",
          "begin": "/\\*(?!\\*)(?!!)",
          "end": "\\*/",
          "patterns": [
            { "include": "#doxygen-tags" }
          ]
        }
      ]
    },
    "doxygen-tags": {
      "patterns": [
        {
          "match": "(@|\\\\)(param|return|returns|retval|brief|details|deprecated|see|since|throws|exception|author|version|note|warning|todo|code|endcode|pre|post|par|invariant|class|struct|union|enum|namespace|file|package|var|fn|def|addtogroup|ingroup|mainpage|example|test|ref|hideinitializer|showinitializer|name|title|date|bug)\\b",
          "name": "keyword.other.documentation.leek"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.leek",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "name": "constant.character.escape.leek", "match": "\\\\." }]
        },
        {
          "name": "string.quoted.single.leek",
          "begin": "'",
          "end": "'",
          "patterns": [{ "name": "constant.character.escape.leek", "match": "\\\\." }]
        }
      ]
    },
    "numbers": {
      "match": "\\b(\\d+\\.?\\d*|\\d*\\.\\d+)([eE][+-]?\\d+)?[mM]?\\b",
      "name": "constant.numeric.leek"
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(abstract|final|private|protected|public|static)\\b",
          "name": "storage.modifier"
        },
        {
          "match": "\\b(var|let|const|global|function|return|if|else|while|for|do|break|continue|in|class|extends|new|this|super|true|false|null|include|as|and|or|not|xor|instanceof|try|catch|throw|switch|case|default|constructor|reserved)\\b",
          "name": "keyword.control"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": "(===|!==|==|!=|<=|>=|[+\\-*/%]=|->|=>|[+\\-*/%<>]=?|\\|\||&&|\\||&|\\^|!|\\?|:|\\.\\.\\.|\\.\\.)",
          "name": "keyword.operator.leek"
        }
      ]
    }
  }
}
